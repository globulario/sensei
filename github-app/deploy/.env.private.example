# Pin the immutable digest emitted by the GitHub App Image workflow.
SENSEI_GITHUB_IMAGE=ghcr.io/globulario/sensei-github-app@sha256:replace-me

# Private GitHub App numeric ID.
SENSEI_GITHUB_APP_ID=replace-me

# Public DNS name whose A/AAAA record resolves to this deployment host.
SENSEI_GITHUB_HOSTNAME=sensei-app.example.com
