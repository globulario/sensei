# Local runtime state (graph-authority marker written by `sensei rebuild`/`sensei serve`).
# .awg/ is the pre-rename name, still honored for existing repos.
/.sensei/
/.awg/

# Go build artifacts
/bin/
/sensei
/awg
/server
/principle-check
/yaml2nt
/loadnt
/proto-scan
*.test
*.out
*.exe
*.so
*.log

# Editor / IDE
.vscode/
.idea/
*.swp

# Local dev data
/.data/
/data/

# Generated proto output is COMMITTED, not ignored.
#
# We check in golang/pb/awareness_graph.pb.go and
# golang/pb/awareness_graph_grpc.pb.go so:
#   - Consumers don't need protoc + plugins installed to build or test.
#   - PRs that change the proto contract show the impact on generated
#     code, making API-level reviews concrete.
#   - `go test ./...` works on a fresh clone without `make proto` first.
# Use `make proto` to regenerate after editing proto/awareness_graph.proto.

# Throwaway spike output
/tmp/
/local/
/.cache/build-awareness-graph/*.meta
*.pyc
__pycache__/

# VS Code extension (editor/vscode) — Node build artifacts.
# package-lock.json IS committed (npm ci in CI needs it); the proto under
# editor/vscode/proto/ is committed (vendored, freshness-checked).
editor/vscode/node_modules/
editor/vscode/out/
editor/vscode/*.vsix

# SCIP index (binary; regenerated by `make scip`)
index.scip
*.scip

# stray go-build binaries (default output name = dir name)
/golang/server/server
bin/
