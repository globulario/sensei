{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://globular.io/sensei/schemas/architectural-closure/v1/role-attestation-receipt.schema.json",
  "title": "Architectural Closure v1 Role Attestation Receipt",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "receipt_id": {"type": "string"},
    "principal_id": {"type": "string"},
    "actor_kind": {"$ref": "common.schema.json#/$defs/actor_kind"},
    "issuer": {"type": "string"},
    "role_ids": {"type": "array", "items": {"type": "string"}},
    "authentication_receipt_digest_sha256": {"type": "string"},
    "issued_at": {"type": "string"},
    "valid_until": {"type": "string"},
    "status": {"$ref": "common.schema.json#/$defs/receipt_status"},
    "receipt_digest_sha256": {"type": "string"}
  },
  "required": [
    "receipt_id",
    "principal_id",
    "actor_kind",
    "issuer",
    "role_ids",
    "issued_at",
    "status"
  ]
}
