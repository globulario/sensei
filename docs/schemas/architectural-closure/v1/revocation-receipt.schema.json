{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://globular.io/sensei/schemas/architectural-closure/v1/revocation-receipt.schema.json",
  "title": "Architectural Closure v1 Revocation Receipt",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "revocation_id": {"type": "string"},
    "revoked_target_id": {"type": "string"},
    "prior_digest_sha256": {"type": "string"},
    "revocation_reason": {"type": "string"},
    "triggering_evidence": {"type": "array", "items": {"type": "string"}},
    "policy_id": {"type": "string"},
    "actor_id": {"type": "string"},
    "revoked_at": {"type": "string"},
    "remediation_task_id": {"type": "string"}
  },
  "required": ["revocation_id", "revoked_target_id", "prior_digest_sha256", "revocation_reason", "policy_id", "actor_id", "revoked_at"]
}

